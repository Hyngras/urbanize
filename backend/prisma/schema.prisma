// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  cidadao
  gestor
}

enum DemandStatus {
  registrada
  em_analise
  encaminhada
  em_atendimento
  resolvida
  cancelada
}

enum DemandCategory {
  vias_publicas
  iluminacao_publica
  coleta_de_lixo
  saneamento
  fiscalizacao
  zeladoria
  outros
}

enum DemandPriority {
  baixa
  media
  alta
}

enum DemandSource {
  cidadao
  sistema_externo
  orgao
}

model Organ {
  id       String @id @default(cuid())
  nome     String @unique
  sigla    String @unique
  email    String?
  telefone String?
  whatsapp String?
  site     String?

  // Categorias que este órgão atende (JSON array de DemandCategory)
  categoriasJson String @default("[]")

  users   User[]
  demands Demand[]
}

model User {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  telefone  String?
  senhaHash String
  role      UserRole @default(cidadao)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organId String?
  organ   Organ?  @relation(fields: [organId], references: [id])

  demands Demand[]
}

model Demand {
  id                     String         @id @default(cuid())
  protocolo              String         @unique
  titulo                 String
  descricao              String
  categoria              DemandCategory @default(outros)
  prioridade             DemandPriority @default(media)
  status                 DemandStatus   @default(registrada)
  nomeSolicitante        String
  emailSolicitante       String
  telefoneSolicitante    String?
  endereco               String
  bairro                 String
  cidade                 String
  referencia             String?
  latitude               Float?
  longitude              Float?
  origem                 DemandSource   @default(cidadao)
  orgaoResponsavel       String?
  imagemUrl              String?
  observacaoGestor       String?
  scoreTriagem           Float?
  sugestaoEncaminhamento String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  userId    String?
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  organId   String?
  organ     Organ?          @relation(fields: [organId], references: [id], onDelete: SetNull)
  historico DemandHistory[]

  @@index([status])
  @@index([categoria])
  @@index([bairro])
  @@index([userId])
}

model DemandHistory {
  id        String       @id @default(cuid())
  status    DemandStatus
  descricao String
  autor     String
  createdAt DateTime     @default(now())

  demandId String
  demand   Demand @relation(fields: [demandId], references: [id], onDelete: Cascade)

  @@index([demandId])
}

model MetricsSnapshot {
  id                        String   @id @default(cuid())
  total                     Int
  porStatusJson             String
  porCategoriaJson          String
  tempoMedioAtendimentoDias Float
  createdAt                 DateTime @default(now())
}
